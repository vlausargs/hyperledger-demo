# Hyperledger Fabric Network Configuration
# This file supports modular deployment across different machines
# Edit this file to configure your deployment environment

# ==============================================================================
# DEPLOYMENT CONTROL
# ==============================================================================
# Set these to true/false to control which components are deployed on this machine
# For modular deployment across machines:
# - Machine A (Orderer): DEPLOY_ORDERER=true, DEPLOY_ORG1=false, DEPLOY_ORG2=false
# - Machine B (Org1): DEPLOY_ORDERER=false, DEPLOY_ORG1=true, DEPLOY_ORG2=false
# - Machine C (Org2): DEPLOY_ORDERER=false, DEPLOY_ORG1=false, DEPLOY_ORG2=true

DEPLOY_ORDERER=true
DEPLOY_ORG1=true
DEPLOY_ORG2=true

# ==============================================================================
# FABRIC VERSION
# ==============================================================================
FABRIC_VERSION=2.4.7
CA_VERSION=1.5.5
BASE_VERSION=2.4.7
THIRDPARTY_VERSION=0.4.24

# ==============================================================================
# NETWORK CONFIGURATION
# ==============================================================================
# Network settings
NETWORK_NAME=fabric_network
COMPOSE_PROJECT_NAME=fabric

# Channel configuration
CHANNEL_NAME=mychannel
CHANNEL_PROFILE=TwoOrgsChannel

# Orderer configuration
ORDERER_GENESIS_PROFILE=TwoOrgsOrdererGenesis
ORDERER_TYPE=etcdraft

# ==============================================================================
# DOMAIN AND PORT CONFIGURATION
# ==============================================================================
# Domains (update these for your actual domain names)
ORDERER_DOMAIN=orderer.example.com
ORG1_DOMAIN=org1.example.com
ORG2_DOMAIN=org2.example.com

# Base ports (can be adjusted for your environment)
ORDERER_PORT=7050
ORDERER_SSL_PORT=7051
PEER0_ORG1_PORT=8051
PEER0_ORG1_SSL_PORT=7052
PEER0_ORG1_METRICS_PORT=8445
PEER0_ORG2_PORT=9051
PEER0_ORG2_SSL_PORT=9052
PEER0_ORG2_METRICS_PORT=9443

# CA ports
CA_ORDERER_PORT=7054
CA_ORG1_PORT=8054
CA_ORG2_PORT=9054

# CouchDB ports
COUCHDB_ORG1_PORT=5984
COUCHDB_ORG2_PORT=7984

# Client API port
CLIENT_API_PORT=8080

# ==============================================================================
# POSTGRESQL CONFIGURATION
# ==============================================================================
# PostgreSQL for Orderer CA
POSTGRES_ORDERER_HOST=postgres-orderer
POSTGRES_ORDERER_PORT=5432
POSTGRES_ORDERER_DB=fabric_ca_orderer
POSTGRES_ORDERER_USER=postgres
POSTGRES_ORDERER_PASSWORD=orderer_postgres_password_change_this

# PostgreSQL for Org1 CA
POSTGRES_ORG1_HOST=postgres-org1
POSTGRES_ORG1_PORT=5433
POSTGRES_ORG1_DB=fabric_ca_org1
POSTGRES_ORG1_USER=postgres
POSTGRES_ORG1_PASSWORD=org1_postgres_password_change_this

# PostgreSQL for Org2 CA
POSTGRES_ORG2_HOST=postgres-org2
POSTGRES_ORG2_PORT=5434
POSTGRES_ORG2_DB=fabric_ca_org2
POSTGRES_ORG2_USER=postgres
POSTGRES_ORG2_PASSWORD=org2_postgres_password_change_this

# PostgreSQL external connection (for multi-machine deployment)
# Set these to the actual hostnames/IPs when deploying across machines
POSTGRES_ORDERER_EXTERNAL_HOST=${POSTGRES_ORDERER_HOST}
POSTGRES_ORG1_EXTERNAL_HOST=${POSTGRES_ORG1_HOST}
POSTGRES_ORG2_EXTERNAL_HOST=${POSTGRES_ORG2_HOST}

# ==============================================================================
# FABRIC CA CONFIGURATION
# ==============================================================================
# Orderer CA
CA_ORDERER_NAME=ca-orderer
CA_ORDERER_HOSTNAME=ca.${ORDERER_DOMAIN}
CA_ORDERER_ENROLLMENT_ID=ca-admin
CA_ORDERER_ENROLLMENT_SECRET=orderer-ca-admin-password-change-this

# Org1 CA
CA_ORG1_NAME=ca-org1
CA_ORG1_HOSTNAME=ca.${ORG1_DOMAIN}
CA_ORG1_ENROLLMENT_ID=ca-admin
CA_ORG1_ENROLLMENT_SECRET=org1-ca-admin-password-change-this

# Org2 CA
CA_ORG2_NAME=ca-org2
CA_ORG2_HOSTNAME=ca.${ORG2_DOMAIN}
CA_ORG2_ENROLLMENT_ID=ca-admin
CA_ORG2_ENROLLMENT_SECRET=org2-ca-admin-password-change-this

# ==============================================================================
# IDENTITY CONFIGURATION
# ==============================================================================
# Orderer identities
ORDERER_ENROLLMENT_ID=orderer1
ORDERER_ENROLLMENT_SECRET=orderer1_password_change_this

# Org1 identities
ORG1_ADMIN_ENROLLMENT_ID=admin
ORG1_ADMIN_ENROLLMENT_SECRET=adminpw
ORG1_USER_ENROLLMENT_ID=user1
ORG1_USER_ENROLLMENT_SECRET=user1_password_change_this
ORG1_PEER_ENROLLMENT_ID=peer0
ORG1_PEER_ENROLLMENT_SECRET=peer0_password_change_this

# Org2 identities
ORG2_ADMIN_ENROLLMENT_ID=admin
ORG2_ADMIN_ENROLLMENT_SECRET=adminpw
ORG2_USER_ENROLLMENT_ID=user1
ORG2_USER_ENROLLMENT_SECRET=user1_password_change_this
ORG2_PEER_ENROLLMENT_ID=peer0
ORG2_PEER_ENROLLMENT_SECRET=peer0_password_change_this

# ==============================================================================
# ORGANIZATION CONFIGURATION
# ==============================================================================
# Organization names
ORDERER_ORG_NAME=OrdererMSP
ORG1_NAME=Org1MSP
ORG2_NAME=Org2MSP

# Organization details
ORG1_COUNTRY=US
ORG1_STATE=California
ORG1_LOCALITY="San Francisco"
ORG1_ORGANIZATION=Org1
ORG1_ORGANIZATIONAL_UNIT=Org1Unit
ORG1_COMMON_NAME=peer0.org1.example.com

ORG2_COUNTRY=US
ORG2_STATE="New York"
ORG2_LOCALITY="New York City"
ORG2_ORGANIZATION=Org2
ORG2_ORGANIZATIONAL_UNIT=Org2Unit
ORG2_COMMON_NAME=peer0.org2.example.com

# ==============================================================================
# COUCHDB CONFIGURATION
# ==============================================================================
# CouchDB credentials
COUCHDB_ORG1_USER=admin
COUCHDB_ORG1_PASSWORD=org1_couchdb_password_change-this
COUCHDB_ORG2_USER=admin
COUCHDB_ORG2_PASSWORD=org2_couchdb_password_change-this

# ==============================================================================
# DOCKER CONFIGURATION
# ==============================================================================
# Docker image versions
FABRIC_IMAGE_TAG=${FABRIC_VERSION}
CA_IMAGE_TAG=${CA_VERSION}
COUCHDB_IMAGE=hyperledger/fabric-couchdb:latest
POSTGRES_IMAGE=pgvector/pgvector:pg14

# Docker resource limits
ORDERER_MEMORY_LIMIT=1024m
ORDERER_MEMORY_RESERVE=512m
ORDERER_CPU_LIMIT=2.0
ORDERER_CPU_RESERVE=1.0

PEER_MEMORY_LIMIT=1024m
PEER_MEMORY_RESERVE=512m
PEER_CPU_LIMIT=2.0
PEER_CPU_RESERVE=1.0

CA_MEMORY_LIMIT=512m
CA_MEMORY_RESERVE=256m
CA_CPU_LIMIT=1.0
CA_CPU_RESERVE=0.5

COUCHDB_MEMORY_LIMIT=512m
COUCHDB_MEMORY_RESERVE=256m
COUCHDB_CPU_LIMIT=1.0
COUCHDB_CPU_RESERVE=0.5

POSTGRES_MEMORY_LIMIT=512m
POSTGRES_MEMORY_RESERVE=256m
POSTGRES_CPU_LIMIT=1.0
POSTGRES_CPU_RESERVE=0.5

# ==============================================================================
# CHAINCODE CONFIGURATION
# ==============================================================================
# Chaincode settings
CHAINCODE_NAME=basic
CHAINCODE_VERSION=1.0
CHAINCODE_SEQUENCE=1
CHAINCODE_LANGUAGE=golang
CHAINCODE_PATH=/opt/gopath/src/github.com/chaincode/basic

# Chaincode endorsement policy (default: any peer from both orgs)
CHAINCODE_ENDORSEMENT_POLICY="AND('Org1MSP.member','Org2MSP.member')"

# ==============================================================================
# CLIENT CONFIGURATION
# ==============================================================================
# Client application settings
CLIENT_NAME=fabric-client
CLIENT_HOST=0.0.0.0
CLIENT_PORT=${CLIENT_API_PORT}
CLIENT_MODE=release

# Client connection settings
CLIENT_TLS_ENABLED=true
CLIENT_TLS_CERTS_PATH=/opt/fabric/crypto
CLIENT_CHANNEL_ID=${CHANNEL_NAME}
CLIENT_CHAINCODE_ID=${CHAINCODE_NAME}

# ==============================================================================
# EXTERNAL HOST CONFIGURATION (for multi-machine deployment)
# ==============================================================================
# When deploying across machines, set these to the actual hostnames/IPs
# These are used for external communication between components on different machines

# Orderer external host (set to actual hostname/IP when deploying on separate machine)
ORDERER_EXTERNAL_HOST=orderer1.orderer.example.com

# Org1 external host (set to actual hostname/IP when deploying on separate machine)
ORG1_EXTERNAL_HOST=org1.example.com

# Org2 external host (set to actual hostname/IP when deploying on separate machine)
ORG2_EXTERNAL_HOST=org2.example.com

# CA external hosts
CA_ORDERER_EXTERNAL_HOST=ca.orderer.example.com
CA_ORG1_EXTERNAL_HOST=ca.org1.example.com
CA_ORG2_EXTERNAL_HOST=ca.org2.example.com

# Peer external hosts
PEER0_ORG1_EXTERNAL_HOST=peer0.org1.example.com
PEER0_ORG2_EXTERNAL_HOST=peer0.org2.example.com

# ==============================================================================
# LOGGING AND MONITORING
# ==============================================================================
# Log levels (CRITICAL, ERROR, WARNING, NOTICE, INFO, DEBUG)
ORDERER_LOG_LEVEL=INFO
PEER_LOG_LEVEL=INFO
CA_LOG_LEVEL=INFO

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================
# TLS settings
TLS_ENABLED=true
TLS_ROOTCERT_FILE=/etc/hyperledger/fabric/tls/ca.crt
TLS_CLIENTAUTHREQUIRED=false
TLS_CLIENTROOTCAS_FILES="[]"

# ==============================================================================
# BACKUP AND MAINTENANCE
# ==============================================================================
# Backup settings
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_RETENTION_DAYS=7

# ==============================================================================
# DEVELOPMENT MODE
# ==============================================================================
# Set to true for development mode (weaker security, more verbose logging)
DEV_MODE=false

# ==============================================================================
# ADDITIONAL CONFIGURATION
# ==============================================================================
# Maximum file descriptors
MAXFD=4096

# Keepalive settings
ORDERER_KEEPALIVE_SERVER_MININTERVAL=1m
ORDERER_KEEPALIVE_SERVER_INTERVAL=2m
ORDERER_KEEPALIVE_SERVER_TIMEOUT=6s

# Gossip settings
PEER_GOSSIP_EXTERNALENDPOINT=peer0.org1.example.com:7051
PEER_GOSSIP_BOOTSTRAP=peer0.org1.example.com:7051
PEER_GOSSIP_LEADER_ELECTION=true
PEER_GOSSIP_ORGLEADER=false
PEER_GOSSIP_USELEADERELECTION=true
